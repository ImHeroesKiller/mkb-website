# ===========================================
# PT Mitra Kreasi Bersama — Environment Variables
# ===========================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# Saat ini website berjalan tanpa env wajib.
# Tambahkan variabel di bawah jika Anda menghubungkan
# form kontak ke API / email service / analytics.

# Site
# NEXT_PUBLIC_SITE_URL=https://mitrakreasibersama.com

# Contact form (opsional — contoh endpoint)
# CONTACT_FORM_ENDPOINT=https://api.example.com/contact
# CONTACT_FORM_API_KEY=

# Analytics (opsional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Mapbox (opsional — jika ingin ganti OpenStreetMap/Leaflet)
# NEXT_PUBLIC_MAPBOX_TOKEN=
